{
  "name": "blocknote-editor",
  "displayName": "BlockNote Markdown Editor",
  "description": "A Notion-like markdown editor for VS Code",
  "version": "0.0.2",
  "publisher": "vikash1a",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "blocknote-editor.markdownEditor",
        "displayName": "BlockNote Editor",
        "selector": [
          {
            "filenamePattern": "*.md"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "compile": "webpack --mode development",
    "watch": "webpack --mode development --watch",
    "package": "webpack --mode production && vsce package",
    "vscode:prepublish": "webpack --mode production",
    "install-local": "npm run package && \"/Applications/Visual Studio Code.app/Contents/Resources/app/bin/code\" --install-extension blocknote-editor-0.0.1.vsix"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "css-loader": "^6.8.1",
    "style-loader": "^3.3.3",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@blocknote/core": "^0.50.0",
    "@blocknote/mantine": "^0.50.0",
    "@blocknote/react": "^0.50.0",
    "@mantine/core": "^9.1.1",
    "@mantine/hooks": "^9.1.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "shiki": "^4.0.2"
  }
}
